<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mediprice.controller.UserPanelController"
            styleClass="root-pane"
            prefWidth="960" prefHeight="680">

    <top>
        <VBox>
            <Region style="-fx-background-color:#10B981;" prefHeight="3" minHeight="3" maxHeight="3" maxWidth="Infinity"/>
            <HBox styleClass="top-bar" spacing="14" alignment="CENTER_LEFT">
                <padding><Insets top="13" right="22" bottom="13" left="22"/></padding>
                <Label text="⬡" style="-fx-font-size:22px; -fx-text-fill:#10B981;"/>
                <Label text="MediPrice" styleClass="nav-title"/>
                <Label fx:id="welcomeLabel" styleClass="nav-subtitle"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Search" styleClass="btn-ghost-small" onAction="#handleSearchMedicines"/>
                <Button text="Sign Out" styleClass="btn-ghost-small" onAction="#handleLogout"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TabPane styleClass="main-tab-pane" tabClosingPolicy="UNAVAILABLE">

            <!-- MY RESERVATIONS -->
            <Tab text="My Reservations">
                <VBox spacing="16">
                    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>

                    <Label text="My Reservations" styleClass="section-title"/>

                    <TableView fx:id="reservationsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                        <columns>
                            <TableColumn fx:id="resMedicineCol" text="Medicine" prefWidth="200"/>
                            <TableColumn fx:id="resPharmacyCol" text="Pharmacy" prefWidth="180"/>
                            <TableColumn fx:id="resQtyCol" text="Qty" prefWidth="70"/>
                            <TableColumn fx:id="resDateCol" text="Reserved On" prefWidth="160"/>
                            <TableColumn fx:id="resStatusCol" text="Status" prefWidth="130"/>
                        </columns>
                        <placeholder>
                            <Label text="No reservations yet" style="-fx-text-fill:#3D5A6F; -fx-font-size:13px;"/>
                        </placeholder>
                    </TableView>

                    <Button fx:id="cancelReservationButton" text="Cancel Selected"
                            styleClass="btn-danger" onAction="#handleCancelReservation"/>
                </VBox>
            </Tab>

            <!-- NEAREST PHARMACY -->
            <Tab text="Find Nearest Pharmacy">
                <VBox spacing="20">
                    <padding><Insets top="22" right="22" bottom="22" left="22"/></padding>

                    <Label text="Find Nearest Pharmacy" styleClass="section-title"/>

                    <HBox spacing="16" alignment="CENTER_LEFT"
                          style="-fx-background-color:#1A2636; -fx-background-radius:10; -fx-border-color:rgba(255,255,255,0.07); -fx-border-width:1; -fx-border-radius:10;">
                        <padding><Insets top="18" right="20" bottom="18" left="20"/></padding>
                        <VBox spacing="5">
                            <Label text="LATITUDE" styleClass="field-label"/>
                            <TextField fx:id="latField" promptText="e.g. 52.2297" styleClass="text-field" prefWidth="160"/>
                        </VBox>
                        <VBox spacing="5">
                            <Label text="LONGITUDE" styleClass="field-label"/>
                            <TextField fx:id="lonField" promptText="e.g. 21.0122" styleClass="text-field" prefWidth="160"/>
                        </VBox>
                        <VBox spacing="5" alignment="BOTTOM_LEFT">
                            <Label text=" " styleClass="field-label"/>
                            <Button text="Find Nearest" styleClass="btn-primary" onAction="#handleFindNearby"/>
                        </VBox>
                    </HBox>

                    <TableView fx:id="pharmacyTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                        <columns>
                            <TableColumn fx:id="pharmNameCol" text="Pharmacy" prefWidth="220"/>
                            <TableColumn fx:id="pharmCityCol" text="City" prefWidth="130"/>
                            <TableColumn fx:id="pharmAddressCol" text="Address" prefWidth="260"/>
                            <TableColumn fx:id="pharmDistCol" text="Distance" prefWidth="120"/>
                        </columns>
                        <placeholder>
                            <Label text="Enter your coordinates above to find nearby pharmacies"
                                   style="-fx-text-fill:#3D5A6F; -fx-font-size:13px;"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </Tab>

        </TabPane>
    </center>

    <bottom>
        <HBox styleClass="bottom-bar" alignment="CENTER_LEFT">
            <padding><Insets top="7" right="18" bottom="7" left="18"/></padding>
            <Label fx:id="statusLabel" styleClass="hint-label"/>
        </HBox>
    </bottom>
</BorderPane>
