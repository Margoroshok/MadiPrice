<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.mediprice.controller.RegisterController"
           styleClass="root-pane"
           prefWidth="900" prefHeight="640">

    <Rectangle fill="#10B981" height="3" arcWidth="0" arcHeight="0"
               StackPane.alignment="TOP_CENTER" width="900"/>

    <VBox alignment="CENTER" spacing="0" maxWidth="420">
        <VBox.margin><Insets top="40" bottom="40"/></VBox.margin>

        <VBox styleClass="card" spacing="24" alignment="CENTER">
            <padding><Insets top="40" right="52" bottom="40" left="52"/></padding>

            <VBox alignment="CENTER" spacing="6">
                <Label text="⬡" style="-fx-font-size:36px; -fx-text-fill:#10B981;"/>
                <Label text="Create Account" styleClass="app-title" style="-fx-font-size:26px;"/>
                <Label text="Join MediPrice today" styleClass="subtitle"/>
            </VBox>

            <Rectangle fill="rgba(255,255,255,0.06)" height="1" width="316"/>

            <VBox spacing="14">
                <VBox spacing="5">
                    <Label text="USERNAME" styleClass="field-label"/>
                    <TextField fx:id="usernameField" promptText="3–30 characters, letters and numbers" styleClass="text-field"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="EMAIL" styleClass="field-label"/>
                    <TextField fx:id="emailField" promptText="your@email.com" styleClass="text-field"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="PASSWORD" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField" promptText="Minimum 6 characters" styleClass="text-field"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="CONFIRM PASSWORD" styleClass="field-label"/>
                    <PasswordField fx:id="confirmPasswordField" promptText="Repeat your password" styleClass="text-field"/>
                </VBox>

                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" maxWidth="Infinity" visible="false"/>
                <Label fx:id="successLabel" styleClass="success-label" wrapText="true" maxWidth="Infinity" visible="false"/>
            </VBox>

            <VBox spacing="10">
                <Button fx:id="registerButton" text="Create Account" styleClass="btn-primary"
                        onAction="#handleRegister" maxWidth="Infinity"/>
                <Button fx:id="backButton" text="Back to Sign In" styleClass="btn-ghost"
                        onAction="#handleBack" maxWidth="Infinity"/>
            </VBox>
        </VBox>
    </VBox>
</StackPane>
